# Axum listen address. Use 0.0.0.0:8080 for a bare self-hosted server.
HOST=0.0.0.0
PORT=8080

# PostgreSQL is required for all persistent state.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/mood_ring
DATABASE_MAX_CONNECTIONS=5

# Optional. Leave empty for same-origin production serving from Axum.
ALLOWED_CORS_ORIGIN=

# Production frontend build directory served by the Axum fallback.
FRONTEND_DIST_DIR=frontend/dist

# Rust tracing filter.
RUST_LOG=info,tower_http=info

# Vite build-time client config. For self-hosted same-origin serving, leave both
# unset or set them to the public origin of this server.
VITE_BACKEND_BASE_URL=
VITE_WS_BASE_URL=
